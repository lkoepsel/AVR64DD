## ----- Active target: AVR64DD32 Curiosity Nano -----
MCU = avr64dd32
SERIAL = /dev/ttyACM0
## Factory default main clock: internal OSCHF at 4 MHz, no prescaler
F_CPU = 4000000UL
USB_BAUD = 250000UL
SOFT_BAUD = 9600UL
## Curiosity Nano on-board nEDBG debugger (UPDI)
PROGRAMMER_TYPE = curiosity_updi
PROGRAMMER_ARGS =

## ----- AVR64DD28 in PDIP, programmed over UPDI with an Atmel-ICE -----
# MCU = avr64dd28
# SERIAL = /dev/ttyACM0
# F_CPU = 4000000UL
# USB_BAUD = 250000UL
# SOFT_BAUD = 9600UL
# PROGRAMMER_TYPE = atmelice_updi
# PROGRAMMER_ARGS = -P usb

## AVR-Dx device support comes from a modern avr-gcc/avr-libc (>= ~14), which
## ships the AVR64DD specs, io headers, and libs. No in-repo device pack.
