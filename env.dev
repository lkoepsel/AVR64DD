## ----- Active target: AVR64DD32 Curiosity Nano -----
MCU = avr64dd32
SERIAL = /dev/ttyACM0
## Factory default main clock: internal OSCHF at 4 MHz, no prescaler
F_CPU = 4000000UL
USB_BAUD = 250000UL
SOFT_BAUD = 9600UL
## Curiosity Nano on-board nEDBG debugger (UPDI)
PROGRAMMER_TYPE = curiosity_updi
PROGRAMMER_ARGS =

## ----- AVR64DD28 in PDIP, programmed over UPDI with an Atmel-ICE -----
# MCU = avr64dd28
# SERIAL = /dev/ttyACM0
# F_CPU = 4000000UL
# USB_BAUD = 250000UL
# SOFT_BAUD = 9600UL
# PROGRAMMER_TYPE = atmelice_updi
# PROGRAMMER_ARGS = -P usb

##########--------------------------------------------------------#########
##########  AVR-Dx device support (Microchip DFP)                 #########
##########  avr-gcc has no AVR64DD specs/headers,                 #########
##########  packs are held in repo, allowing easier initial setup #########
##########  -B  finds device-specs + crt<dev>.o + lib<dev>.a.     #########
##########  -isystem finds <avr/io.h> -> ioavr64dd*.h             #########
##########--------------------------------------------------------#########
DFP = $(DEPTH)packs/AVR-Dx_DFP
DEVICE_FLAGS = -B $(DFP)/gcc/dev/$(MCU) -isystem $(DFP)/include
